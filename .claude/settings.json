{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/pr-guard.js"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/destructive-git-guard.js"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/commit-guard.js"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/deploy-guard.js"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/git-push-guard.js"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/email-send-guard.js"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/design-doc-guard.js"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/prod-gateway-guard.js"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/session-inject.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/sync-entry-points.js"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/cascade-check.js"
          }
        ]
      }
    ]
  }
}
